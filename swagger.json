{
  "openapi": "3.0.1",
  "info": {
    "title": "API CRUD de Tarefas",
    "version": "v1"
  },
  "servers": [
    { "url": "http://localhost:3333", "description": "Servidor local" }
  ],
  "paths": {
    "/tasks": {
      "post": {
        "summary": "Create task",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  }
}
